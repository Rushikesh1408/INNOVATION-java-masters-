APP_NAME=Java Masters Exam Engine
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./java_masters.db
# Generate a secure secret before deployment, for example:
# openssl rand -hex 32
ADMIN_JWT_SECRET=dev_local_secret_please_change_1234567890
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
LEADERBOARD_CACHE_TTL_SECONDS=30
